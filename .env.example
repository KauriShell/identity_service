# TrustBridge identity_service — copy to .env and adjust.
# Full stack (Postgres, Redis, Mailpit): use repo-root docker-compose.yml (port 3000).

RAILS_ENV=development
RAILS_LOG_LEVEL=info

# --- Database (PostgreSQL primary + replica) ---
DATABASE_PRIMARY_HOST=localhost
DATABASE_PRIMARY_PORT=5432
DATABASE_REPLICA_HOST=localhost
DATABASE_REPLICA_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=identity_service_development
DATABASE_TEST_NAME=identity_service_test
# Optional: override test connection (CI/specs)
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/identity_service_test
FORCE_PRIMARY_READS=false

# --- Redis (Rack::Attack, JWT denylist, cache, Action Cable) ---
REDIS_URL=redis://localhost:6379/1

# --- Auth & secrets (must match escrow_service / payment_service for JWT) ---
DEVISE_JWT_SECRET_KEY=change-me-to-match-other-services
DEVISE_PEPPER=change-me
SERVICE_TOKEN_SALT=change-me

# Service tenant token seeded for internal API (X-Service-Token); must match escrow_service IDENTITY_SERVICE_TOKEN
IDENTITY_SERVICE_TOKEN=development_escrow_service_token

# --- HTTP ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:19006
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Mail & URL helpers (Devise / Action Mailer links) ---
DEVISE_MAILER_SENDER=no-reply@trustbridge.local
MAILER_FROM=TrustBridge <noreply@trustbridge.local>
DEFAULT_URL_HOST=localhost
DEFAULT_URL_PORT=3000
DEFAULT_URL_PROTOCOL=http

# --- KYC uploads (S3 + KMS via Active Storage) ---
AWS_BUCKET=identity-service-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_KMS_KEY_ID=local

# --- Background jobs (Solid Queue; run bin/jobs when USE_SOLID_QUEUE=1) ---
USE_SOLID_QUEUE=1
JOB_CONCURRENCY=1
KYC_JOB_CONCURRENCY=1

# --- Dev email (Mailpit; root compose exposes SMTP on 1025) ---
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
MAILPIT_DOMAIN=localhost
# MAILPIT_USER=
# MAILPIT_PASS=

# --- Mission Control Jobs UI (/jobs) ---
MISSION_CONTROL_JOBS_USER=dev
MISSION_CONTROL_JOBS_PASSWORD=change-me

# --- Optional: db:seed overrides ---
# SEED_ADMIN_EMAIL=admin@trustbridge.local
# SEED_ADMIN_PASSWORD=AdminPass1234!
# SEED_SUPERADMIN_EMAIL=superadmin@trustbridge.local
# SEED_SUPERADMIN_PASSWORD=SuperAdminPass1234!

# --- Production only (not for local .env) ---
# SECRET_KEY_BASE=generate-with-bin-rails-secret
# DATABASE_POOL=10
# RAILS_MASTER_KEY=from config/master.key
